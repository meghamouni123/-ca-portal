# Copy this to .env and fill in your values

# ── PostgreSQL (set this to use PostgreSQL instead of SQLite) ──
# DATABASE_URL=postgresql://username:password@localhost:5432/ca_portal
DATABASE_URL=postgresql://postgres:1234@localhost:5432/ca_portal

# ── SQLite (default, no setup needed) ──
# DB_PATH=ca_articles.db



# ── Scheduler interval (minutes)
FETCH_INTERVAL_MINUTES=60
